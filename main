#!/bin/bash

CONFIG_DIR="/etc/telemt_docker"
CONFIG_FILE="$CONFIG_DIR/config.toml"
USER_LIST="$CONFIG_DIR/users.list"
CONTAINER_NAME="telemt"

GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

show_menu() {
    clear
    echo -e "${CYAN}==========================================${NC}"
    echo -e "${CYAN}    TELEMT KEY MANAGER v2.5 (STABLE)      ${NC}"
    echo -e "${CYAN}==========================================${NC}"
    echo -e "1. 🚀 Установить / Пересобрать прокси"
    echo -e "2. 🔑 Добавить новый ключ"
    echo -e "3. 🗑️  Удалить ключ"
    echo -e "4. 📢 Настроить рекламный тег (Ad Tag)"
    echo -e "5. 📋 Список ключей и данные для бота"
    echo -e "6. 📊 Мониторинг (логи)"
    echo -e "7. ❌ Полное удаление прокси"
    echo -e "0. Выход"
    echo -e "${CYAN}------------------------------------------${NC}"
    read -p "Выберите пункт: " choice
    case $choice in
        1) install_proxy ;;
        2) add_key ;;
        3) delete_key ;;
        4) set_ad_tag ;;
        5) show_links ;;
        6) docker logs -f $CONTAINER_NAME --tail 50 ;;
        7) uninstall_proxy ;;
        0) exit 0 ;;
        *) echo -e "${RED}Ошибка!${NC}"; sleep 1; show_menu ;;
    esac
}

generate_config() {
    DOMAIN=$(cat "$CONFIG_DIR/domain.val" 2>/dev/null || echo "github.com")
    TAG_LINE=""
    [ -f "$CONFIG_DIR/ad_tag.val" ] && TAG_LINE="ad_tag = \"$(cat $CONFIG_DIR/ad_tag.val)\""

    cat > "$CONFIG_FILE" << EOT
[general]
use_middle_proxy = false
$TAG_LINE

[general.modes]
classic = false
secure = false
tls = true

[server]
port = 443

[server.api]
enabled = true

[censorship]
tls_domain = "$DOMAIN"

[access.users]
EOT
    cat "$USER_LIST" >> "$CONFIG_FILE"
}

install_proxy() {
    echo -e "${YELLOW}--- Установка ---${NC}"
    read -p "Порт (Enter для 443): " PORT
    PORT=${PORT:-443}

    echo -e "Выбор домена (default 1):"
    echo "1) github.com  2) google.com  3) cloudflare.com  4) apple.com"
    read -p "> " D_CH
    case $D_CH in
        2) D="google.com" ;; 3) D="cloudflare.com" ;; 4) D="itunes.apple.com" ;; *) D="github.com" ;;
    esac

    docker rm -f $CONTAINER_NAME 2>/dev/null
    rm -rf "$CONFIG_DIR" && mkdir -p "$CONFIG_DIR"
    echo "$D" > "$CONFIG_DIR/domain.val"
    echo "$PORT" > "$CONFIG_DIR/port.val"

    read -p "Назовите первый ключ (напр. admin): " KNAME
    KNAME=${KNAME:-admin}
    KSECRET=$(openssl rand -hex 16)
    echo "$KNAME = \"$KSECRET\"" > "$USER_LIST"

    generate_config
    chmod -R 777 "$CONFIG_DIR"

    docker run -d --name $CONTAINER_NAME --restart unless-stopped \
      -p $PORT:443 -p 9091:9091 -v "$CONFIG_DIR:/app:ro" \
      --cap-add NET_BIND_SERVICE --ulimit nofile=65536:65536 \
      whn0thacked/telemt-docker:latest /app/config.toml

    echo -e "${GREEN}Запуск... Подождите 5 сек...${NC}"
    sleep 5
    show_links
}

add_key() {
    if [ ! -f "$USER_LIST" ]; then echo -e "${RED}Сначала установите прокси!${NC}"; sleep 2; return; fi
    read -p "Назовите новый ключ: " KNAME
    [ -z "$KNAME" ] && return
    echo "$KNAME = \"$(openssl rand -hex 16)\"" >> "$USER_LIST"
    generate_config
    docker restart $CONTAINER_NAME
    echo -e "${GREEN}Ключ добавлен и применен.${NC}"
    sleep 2
    show_links
}

delete_key() {
    if [ ! -f "$USER_LIST" ]; then return; fi
    echo -e "${YELLOW}Текущие ключи:${NC}"
    cut -d' ' -f1 "$USER_LIST"
    read -p "Введите имя ключа для удаления: " KNAME
    sed -i "/^$KNAME =/d" "$USER_LIST"
    generate_config
    docker restart $CONTAINER_NAME
    echo -e "${RED}Ключ удален.${NC}"; sleep 2
}

set_ad_tag() {
    echo -e "${YELLOW}Ad Tag привязывается к серверу целиком.${NC}"
    read -p "Введите Ad Tag из @MTProxybot (или Enter для удаления): " NEW_TAG
    [ -n "$NEW_TAG" ] && echo "$NEW_TAG" > "$CONFIG_DIR/ad_tag.val" || rm -f "$CONFIG_DIR/ad_tag.val"
    generate_config
    docker restart $CONTAINER_NAME
    echo -e "${GREEN}Настройки обновлены!${NC}"; sleep 2
}

show_links() {
    if ! docker ps | grep -q $CONTAINER_NAME; then echo "Ошибка: Контейнер не запущен"; sleep 2; return; fi
    IP=$(curl -s ifconfig.me)
    PORT=$(cat "$CONFIG_DIR/port.val")
    DOMAIN=$(cat "$CONFIG_DIR/domain.val")
    DOMAIN_HEX=$(echo -n $DOMAIN | od -A n -t x1 | tr -d ' \n')

    echo -e "\n${GREEN}--- СПИСОК ВАШИХ КЛЮЧЕЙ ---${NC}"

    while read -r line; do
        NAME=$(echo $line | cut -d' ' -f1)
        SECRET=$(echo $line | cut -d'"' -f2)

        echo -e "${CYAN}Ключ:${NC} $NAME"
        echo -e "🔗 Для Telegram: ${YELLOW}tg://proxy?server=$IP&port=$PORT&secret=ee${SECRET}${DOMAIN_HEX}${NC}"
        echo -e "🤖 Для бота @MTProxybot:"
        echo -e "   Хост:   ${YELLOW}${IP}:${PORT}${NC}"
        echo -e "   Секрет: ${YELLOW}${SECRET}${NC}"
        echo -e "------------------------------------------------"
    done < "$USER_LIST"

    read -p "Нажмите Enter для возврата..."
}

uninstall_proxy() {
    docker rm -f $CONTAINER_NAME; rm -rf "$CONFIG_DIR"; echo "Удалено"; sleep 1
}

while true; do show_menu; done
